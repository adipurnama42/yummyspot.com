Options -Indexes
RewriteEngine On
RewriteBase /yummyspot/

# в”Ђв”Ђ Abaikan file/folder yang memang ada в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# в”Ђв”Ђ Auth в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteRule ^login$              login.php [L,QSA]
RewriteRule ^register$           register.php [L,QSA]
RewriteRule ^logout$             logout.php [L,QSA]

# в”Ђв”Ђ Halaman utama в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteRule ^explore$            explore.php [L,QSA]
RewriteRule ^katalog$            catalog.php [L,QSA]
RewriteRule ^katalog/([^/]+)$    catalog-detail.php?slug=$1 [L,QSA]
RewriteRule ^wishlist$           wishlist.php [L,QSA]
RewriteRule ^notifikasi$         notifications.php [L,QSA]
RewriteRule ^laporan-saya$       my-reports.php [L,QSA]

# в”Ђв”Ђ Post & Profil в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteRule ^post/([0-9]+)$      post.php?id=$1 [L,QSA]
RewriteRule ^user/([^/]+)$       profile.php?u=$1 [L,QSA]
RewriteRule ^laporan$            report.php [L,QSA]

# в”Ђв”Ђ Owner Panel в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteRule ^owner$              owner/dashboard.php [L,QSA]
RewriteRule ^owner/katalog$      owner/catalogs.php [L,QSA]
RewriteRule ^owner/tambah$       owner/catalog-create.php [L,QSA]
RewriteRule ^owner/edit/([0-9]+)$ owner/catalog-edit.php?id=$1 [L,QSA]
RewriteRule ^owner/ulasan$       owner/reviews.php [L,QSA]
RewriteRule ^owner/analitik$     owner/analytics.php [L,QSA]

# в”Ђв”Ђ CS Panel в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteRule ^cs$                 cs/dashboard.php [L,QSA]
RewriteRule ^cs/katalog/([0-9]+)$ cs/catalog-detail.php?id=$1 [L,QSA]

# в”Ђв”Ђ Admin Panel в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteRule ^admin$              admin/dashboard.php [L,QSA]
RewriteRule ^admin/cs$           admin/manage-cs.php [L,QSA]

# в”Ђв”Ђ Fallback: root ke index в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteRule ^$                   index.php [L]
